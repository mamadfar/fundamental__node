<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Home</title>
</head>
<body>
    <%= n %>

    <%
        let c = 55;
        let d = n * c;
    %>

    <p>The value of d is: <%= d %></p>

    <ul>
        <%- data.map(item => `<li>${item}</li>`).join('') %>
    </ul>

    <ul>
        <% for(let item of data){ %>
            <li><%= item %></li>
        <% } %>
    </ul>

    <%- include('component') %>
</body>
</html>